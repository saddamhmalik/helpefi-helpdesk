APP_NAME=helpefi
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://helpdesk.test:8081

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

TELESCOPE_ENABLED=true
TELESCOPE_DB_CONNECTION=central

DB_CONNECTION=central
DB_DRIVER=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=helpdesk_central
DB_USERNAME=helpdesk
DB_PASSWORD=secret

CENTRAL_APP_DOMAIN=helpdesk.test
TENANCY_CUSTOM_DOMAIN_CNAME=tenants.helpdesk.test
TENANCY_DATABASE_PREFIX=tenant_

SESSION_DRIVER=database
SESSION_CONNECTION=central
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false

QUEUE_CONNECTION=redis
CACHE_STORE=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_QUEUE=default

REALTIME_WS_URL=ws://localhost:8080
REALTIME_WS_HOST=0.0.0.0
REALTIME_WS_PORT=8080
REALTIME_REDIS_PREFIX=helpdesk:realtime:
REALTIME_TOKEN_TTL=3600

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@helpdesk.test"
MAIL_FROM_NAME="${APP_NAME}"

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

INBOUND_EMAIL_TOKEN=dev-inbound-token

RAZORPAY_ENABLED=false
RAZORPAY_KEY=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=inr
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_PROFESSIONAL=
RAZORPAY_PLAN_ENTERPRISE=
RAZORPAY_PLAN_STARTER_YEARLY=
RAZORPAY_PLAN_PROFESSIONAL_YEARLY=
RAZORPAY_PLAN_ENTERPRISE_YEARLY=

BILLING_DEFAULT_PLAN=professional
BILLING_TRIAL_DAYS=14
BILLING_CURRENCY=INR

BACKUP_SCHEDULE_ENABLED=false

WAIT_FOR_DB=true
WAIT_FOR_REDIS=true
DOCKER_OPTIMIZE=false
