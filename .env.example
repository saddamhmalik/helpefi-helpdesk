APP_NAME=Helpefi
APP_VERSION=1.0.0
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://helpdesk.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_SLOW_QUERY_LOG=true
DB_SLOW_QUERY_LOG_TO_FILE=true
DB_SLOW_QUERY_STORE=true
DB_SLOW_QUERY_THRESHOLD_MS=500
DB_SLOW_QUERY_REMOTE_THRESHOLD_MS=1500
DB_SLOW_QUERY_LOG_BINDINGS=false

TELESCOPE_ENABLED=true
TELESCOPE_DB_CONNECTION=central

DB_CONNECTION=central
DB_DRIVER=mysql
CENTRAL_DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=helpdesk_central
DB_USERNAME=root
DB_PASSWORD=

CENTRAL_APP_DOMAIN=helpdesk.test
CENTRAL_OG_IMAGE_URL=
MARKETING_SITE_URL=https://helpefi.com
MARKETING_CONTACT_EMAIL=hello@helpefi.com
MARKETING_CONTACT_IP_MAX=5
MARKETING_CONTACT_IP_DECAY=1
MARKETING_CONTACT_EMAIL_MAX=3
MARKETING_CONTACT_EMAIL_DECAY=60
MARKETING_CONTACT_MIN_SECONDS=3
MARKETING_CONTACT_MAX_AGE=120
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
GOOGLE_ANALYTICS_ID=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
MARKETING_TWITTER_SITE=@helpefi
MARKETING_ORG_NAME=Helpefi
MARKETING_PARENT_COMPANY_NAME=Codikal
MARKETING_PARENT_COMPANY_URL=https://codikal.com
CENTRAL_OG_IMAGE_URL=https://helpefi.com/og-image.png
MARKETING_OG_IMAGE_HOME=/og-image.png
MARKETING_OG_IMAGE_FEATURES=/og-image.png
MARKETING_OG_IMAGE_PRICING=/og-image.png
MARKETING_OG_IMAGE_AI=/og/ai-helpdesk.png
MARKETING_OG_IMAGE_COMPARE_ZENDESK=/og/vs-zendesk.png
MARKETING_OG_IMAGE_MIGRATE_ZENDESK=/og/migrate-zendesk.png
TENANCY_CUSTOM_DOMAIN_CNAME=tenants.helpdesk.test
CENTRAL_ADMIN_PASSWORD=
TENANCY_DATABASE_PREFIX=tenant_

# Enterprise: allow workspaces to use customer-owned RDS and S3/R2 buckets
TENANT_BYO_ENABLED=false
HELPEFI_EGRESS_IPS=
TENANT_BYO_CONNECTION_TIMEOUT=10
TENANT_BYO_DB_PERSISTENT=false
TENANT_BYO_DB_COMPRESS=true
TENANT_BYO_MYSQL_CLIENT_BINARY_PATH=
TENANT_BYO_DATABASE_MIGRATION_TIMEOUT=3600
TENANT_BYO_SIGNED_URL_MINUTES=30
TENANT_BYO_HEALTH_FAILURE_THRESHOLD=3
TENANT_BYO_VERIFY_RATE_LIMIT=5
TENANT_BYO_REQUIRES_ENTERPRISE=true
TENANT_BYO_DROP_MANAGED_DB_AFTER_MIGRATION=false
TENANT_BYO_DELETE_LOCAL_FILES_AFTER_MIGRATION=true
TENANT_BYO_ALERT_ON_FAILURE=true
TENANT_BYO_ALERT_EMAILS=
TENANT_BYO_TELESCOPE_REDACT_EXTERNAL=true

# Optional live BYO integration tests (phpunit)
# BYO_INTEGRATION_MYSQL_HOST=
# BYO_INTEGRATION_MYSQL_PORT=3306
# BYO_INTEGRATION_MYSQL_DATABASE=helpdesk_external_test
# BYO_INTEGRATION_MYSQL_USERNAME=root
# BYO_INTEGRATION_MYSQL_PASSWORD=

# Deployment mode: saas (default) or self_hosted
HELPEFI_DEPLOYMENT_MODE=saas
HELPEFI_LICENSE_KEY=
HELPEFI_LICENSE_HMAC_KEY=
HELPEFI_LICENSE_GRACE_HOURS=72

# Required for external S3/R2 storage (composer packages):
# league/flysystem-aws-s3-v3, aws/aws-sdk-php

SESSION_DRIVER=database
SESSION_CONNECTION=central
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
REDIS_QUEUE=default
TENANCY_CENTRAL_QUEUE_CONNECTION=central
AUDIT_QUEUE=default
AUDIT_QUEUE_CONNECTION=

CACHE_STORE=redis

# Use smtp/ses/postmark/resend in production. "log" only writes to storage/logs/laravel.log.
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="noreply@helpdesk.test"
MAIL_FROM_NAME="${APP_NAME}"
CENTRAL_MAIL_FROM_ADDRESS="${MAIL_FROM_ADDRESS}"
CENTRAL_MAIL_FROM_NAME="${MAIL_FROM_NAME}"

VITE_APP_NAME="${APP_NAME}"

REALTIME_WS_URL=ws://127.0.0.1:8080
REALTIME_WS_HOST=127.0.0.1
REALTIME_WS_PORT=8080
REALTIME_REDIS_PREFIX=helpdesk:realtime:
REALTIME_TOKEN_TTL=3600
REALTIME_ENABLED=true

INBOUND_EMAIL_TOKEN=
TRUSTED_PROXIES=
API_TOKEN_TTL_DAYS=90

# Single redirect URI for all workspaces (defaults to MARKETING_SITE_URL, e.g. https://helpefi.com):
#   Google:    {MAIL_OAUTH_CALLBACK_URL}/oauth/mail/google/callback
#   Microsoft: {MAIL_OAUTH_CALLBACK_URL}/oauth/mail/microsoft/callback
#   Zoho:      {MAIL_OAUTH_CALLBACK_URL}/oauth/mail/zoho/callback
MAIL_OAUTH_CALLBACK_URL=

GOOGLE_MAIL_CLIENT_ID=
GOOGLE_MAIL_CLIENT_SECRET=

MICROSOFT_MAIL_CLIENT_ID=
MICROSOFT_MAIL_CLIENT_SECRET=
MICROSOFT_MAIL_TENANT=common

ZOHO_MAIL_CLIENT_ID=
ZOHO_MAIL_CLIENT_SECRET=
ZOHO_MAIL_REGION=com

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

AI_MARKETING_DEMO_ENABLED=true

BILLING_DEFAULT_PLAN=enterprise
BILLING_TRIAL_DAYS=14
BILLING_CANCELLATION_GRACE_DAYS=3

BILLING_CURRENCY=INR

RAZORPAY_ENABLED=false
RAZORPAY_KEY=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=inr
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_PROFESSIONAL=
RAZORPAY_PLAN_ENTERPRISE=
RAZORPAY_PLAN_STARTER_YEARLY=
RAZORPAY_PLAN_PROFESSIONAL_YEARLY=
RAZORPAY_PLAN_ENTERPRISE_YEARLY=

BACKUP_DISK=local
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE_ENABLED=false
BACKUP_SCHEDULE_FREQUENCY=daily
BACKUP_SCHEDULE_WEEKDAY=1
BACKUP_SCHEDULE_TIME=02:00
