APP_NAME=helpefi
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://helpdesk.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

TELESCOPE_ENABLED=true
TELESCOPE_DB_CONNECTION=central

DB_CONNECTION=central
DB_DRIVER=mysql
CENTRAL_DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=helpdesk_central
DB_USERNAME=root
DB_PASSWORD=

CENTRAL_APP_DOMAIN=helpdesk.test
CENTRAL_OG_IMAGE_URL=
MARKETING_SITE_URL=https://helpefi.com
MARKETING_CONTACT_EMAIL=hello@helpefi.com
GOOGLE_ANALYTICS_ID=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
MARKETING_TWITTER_SITE=@helpefi
MARKETING_ORG_NAME=Helpefi
MARKETING_PARENT_COMPANY_NAME=Codikal
MARKETING_PARENT_COMPANY_URL=https://codikal.com
TENANCY_CUSTOM_DOMAIN_CNAME=tenants.helpdesk.test
CENTRAL_ADMIN_PASSWORD=
TENANCY_DATABASE_PREFIX=tenant_

SESSION_DRIVER=database
SESSION_CONNECTION=central
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
REDIS_QUEUE=default
TENANCY_CENTRAL_QUEUE_CONNECTION=central
AUDIT_QUEUE=default
AUDIT_QUEUE_CONNECTION=

CACHE_STORE=redis

# Use smtp/ses/postmark/resend in production. "log" only writes to storage/logs/laravel.log.
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="noreply@helpdesk.test"
MAIL_FROM_NAME="${APP_NAME}"
CENTRAL_MAIL_FROM_ADDRESS="${MAIL_FROM_ADDRESS}"
CENTRAL_MAIL_FROM_NAME="${MAIL_FROM_NAME}"

VITE_APP_NAME="${APP_NAME}"

REALTIME_WS_URL=ws://127.0.0.1:8080
REALTIME_WS_HOST=127.0.0.1
REALTIME_WS_PORT=8080
REALTIME_REDIS_PREFIX=helpdesk:realtime:
REALTIME_TOKEN_TTL=3600

INBOUND_EMAIL_TOKEN=dev-inbound-token

# Single redirect URI for all workspaces (defaults to MARKETING_SITE_URL, e.g. https://helpefi.com):
#   Google:    {MAIL_OAUTH_CALLBACK_URL}/oauth/mail/google/callback
#   Microsoft: {MAIL_OAUTH_CALLBACK_URL}/oauth/mail/microsoft/callback
#   Zoho:      {MAIL_OAUTH_CALLBACK_URL}/oauth/mail/zoho/callback
MAIL_OAUTH_CALLBACK_URL=

GOOGLE_MAIL_CLIENT_ID=
GOOGLE_MAIL_CLIENT_SECRET=

MICROSOFT_MAIL_CLIENT_ID=
MICROSOFT_MAIL_CLIENT_SECRET=
MICROSOFT_MAIL_TENANT=common

ZOHO_MAIL_CLIENT_ID=
ZOHO_MAIL_CLIENT_SECRET=
ZOHO_MAIL_REGION=com

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

AI_MARKETING_DEMO_ENABLED=true

BILLING_DEFAULT_PLAN=enterprise
BILLING_TRIAL_DAYS=14
BILLING_CANCELLATION_GRACE_DAYS=3

BILLING_CURRENCY=INR

RAZORPAY_ENABLED=false
RAZORPAY_KEY=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=inr
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_PROFESSIONAL=
RAZORPAY_PLAN_ENTERPRISE=
RAZORPAY_PLAN_STARTER_YEARLY=
RAZORPAY_PLAN_PROFESSIONAL_YEARLY=
RAZORPAY_PLAN_ENTERPRISE_YEARLY=

BACKUP_DISK=local
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE_ENABLED=false
BACKUP_SCHEDULE_FREQUENCY=daily
BACKUP_SCHEDULE_WEEKDAY=1
BACKUP_SCHEDULE_TIME=02:00
