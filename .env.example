APP_NAME=Helpdesk
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://helpdesk.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=central
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=helpdesk_central
DB_USERNAME=root
DB_PASSWORD=

CENTRAL_APP_DOMAIN=helpdesk.test
TENANCY_DATABASE_PREFIX=helpdesk_tenant_

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
REDIS_QUEUE=default
AUDIT_QUEUE=default
AUDIT_QUEUE_CONNECTION=

CACHE_STORE=redis

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@helpdesk.test"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

REALTIME_WS_URL=ws://127.0.0.1:8080
REALTIME_WS_PORT=8080
REALTIME_REDIS_PREFIX=helpdesk:realtime:
REALTIME_TOKEN_TTL=3600

INBOUND_EMAIL_TOKEN=dev-inbound-token

GOOGLE_MAIL_CLIENT_ID=
GOOGLE_MAIL_CLIENT_SECRET=

MICROSOFT_MAIL_CLIENT_ID=
MICROSOFT_MAIL_CLIENT_SECRET=
MICROSOFT_MAIL_TENANT=common

ZOHO_MAIL_CLIENT_ID=
ZOHO_MAIL_CLIENT_SECRET=
ZOHO_MAIL_REGION=com

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
