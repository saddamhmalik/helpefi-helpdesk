APP_NAME=helpefi
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://helpdesk.example.com

HELPEFI_DEPLOYMENT_MODE=self_hosted
HELPEFI_LICENSE_KEY=
HELPEFI_LICENSE_GRACE_HOURS=72

DB_CONNECTION=central
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=helpdesk_central
DB_USERNAME=helpdesk
DB_PASSWORD=change-me

CENTRAL_APP_DOMAIN=helpdesk.example.com
TENANCY_DATABASE_PREFIX=tenant_
TENANT_BYO_ENABLED=true
TENANT_BYO_REQUIRES_ENTERPRISE=false

SESSION_DRIVER=database
SESSION_CONNECTION=central
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PORT=6379
CACHE_STORE=redis

FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

RAZORPAY_ENABLED=false
TELESCOPE_ENABLED=false

DB_SLOW_QUERY_LOG=true
DB_SLOW_QUERY_STORE=true
DB_SLOW_QUERY_THRESHOLD_MS=500
DB_SLOW_QUERY_REMOTE_THRESHOLD_MS=1500

HTTP_PORT=80
REALTIME_PORT=8080
MYSQL_ROOT_PASSWORD=change-me-root
