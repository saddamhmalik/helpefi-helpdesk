{
  "info": {
    "_postman_id": "helpdesk-api-v1",
    "name": "Helpdesk API",
    "description": "Helpdesk REST API v1. Login first to obtain a bearer token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://helpdesk.test/api/v1" },
    { "key": "token", "value": "" },
    { "key": "ticketId", "value": "1" },
    { "key": "viewId", "value": "1" },
    { "key": "userId", "value": "1" },
    { "key": "messageId", "value": "1" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@helpdesk.test\",\n  \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Meta",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/tickets/meta"
          }
        },
        {
          "name": "List tickets",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/tickets?search=&status_id=&priority_id=&assigned_to=&watching=",
              "host": ["{{baseUrl}}"],
              "path": ["tickets"],
              "query": [
                { "key": "search", "value": "" },
                { "key": "status_id", "value": "" },
                { "key": "priority_id", "value": "" },
                { "key": "assigned_to", "value": "" },
                { "key": "watching", "value": "" },
                { "key": "view_id", "value": "{{viewId}}", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create ticket",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('ticketId', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"API test ticket\",\n  \"description\": \"Created from Postman\",\n  \"ticket_status_id\": 1,\n  \"ticket_priority_id\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/tickets"
          }
        },
        {
          "name": "Show ticket",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/tickets/{{ticketId}}"
          }
        },
        {
          "name": "Update ticket",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Updated subject\",\n  \"ticket_status_id\": 1,\n  \"ticket_priority_id\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/tickets/{{ticketId}}"
          }
        },
        {
          "name": "Reply",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"body\": \"Reply from Postman\",\n  \"is_internal\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/tickets/{{ticketId}}/reply"
          }
        },
        {
          "name": "Upload attachment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": [] }]
            },
            "url": "{{baseUrl}}/tickets/{{ticketId}}/attachments"
          }
        },
        {
          "name": "Add watcher",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/tickets/{{ticketId}}/watchers"
          }
        },
        {
          "name": "Remove watcher",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/tickets/{{ticketId}}/watchers/{{userId}}"
          }
        },
        {
          "name": "Merge ticket",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_ticket_id\": 2\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/tickets/{{ticketId}}/merge"
          }
        },
        {
          "name": "Split ticket",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_message_id\": {{messageId}},\n  \"subject\": \"Split ticket\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/tickets/{{ticketId}}/split"
          }
        }
      ]
    },
